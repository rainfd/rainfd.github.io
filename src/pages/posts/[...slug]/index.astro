---
import { getLocaleFromUrl } from "@/utils/locale";
import { getCollection, render } from "astro:content";
import { getRelativeLocaleUrl } from "@/utils/i18n-shim";
import PostLayout from "@/layouts/PostLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Datetime from "@/components/Datetime.astro";
import Tag from "@/components/Tag.astro";
import { getPostSlug, getPostUrl } from "@/utils/getPostPaths";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { slugifyStr } from "@/utils/slugify";
import { toTransitionName } from "@/utils/toTransitionName";
import EditPost from "./_components/EditPost.astro";
import ShareLinks from "./_components/ShareLinks.astro";
import BackButton from "./_components/BackButton.astro";
import BackToTopButton from "./_components/BackToTopButton.astro";
import AdjacentPostNav from "./_components/AdjacentPostNav.astro";
import config from "@/config";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  // Group and sort by locale so prev/next stay within the same language
  const byLocale = new Map<string, typeof posts>();
  for (const post of posts) {
    const loc = post.data.locale;
    if (!byLocale.has(loc)) byLocale.set(loc, []);
    byLocale.get(loc)!.push(post);
  }
  for (const [loc, group] of byLocale) {
    byLocale.set(loc, getSortedPosts(group));
  }

  const routes: any[] = [];
  for (const [, sortedPosts] of byLocale) {
    for (let i = 0; i < sortedPosts.length; i++) {
      const post = sortedPosts[i];
      routes.push({
        params: { slug: getPostSlug(post.id, post.filePath, post.data.slug) },
        props: {
          post,
          prevPost: i > 0
            ? {
                id: sortedPosts[i - 1].id,
                title: sortedPosts[i - 1].data.title,
                filePath: sortedPosts[i - 1].filePath,
                slug: sortedPosts[i - 1].data.slug,
              }
            : null,
          nextPost: i < sortedPosts.length - 1
            ? {
                id: sortedPosts[i + 1].id,
                title: sortedPosts[i + 1].data.title,
                filePath: sortedPosts[i + 1].filePath,
                slug: sortedPosts[i + 1].data.slug,
              }
            : null,
        },
      });
    }
  }
  return routes;
}

const { post, prevPost, nextPost } = Astro.props;
const locale = getLocaleFromUrl(Astro.url);

const {
  title,
  description,
  ogImage: initOgImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  timezone,
  tags,
  hideEditPost,
} = post.data;

const { Content } = await render(post);

let ogImageUrl: string | undefined;

if (typeof initOgImage === "string") {
  ogImageUrl = initOgImage;
} else if (initOgImage?.src) {
  ogImageUrl = initOgImage.src;
}

if (!ogImageUrl && config.features.dynamicOgImage) {
  const postUrl = getPostUrl(post.id, post.filePath, locale, post.data.slug).replace(
    /\/+$/,
    ""
  );
  ogImageUrl = `${postUrl}/index.png`;
}

const ogImage = ogImageUrl
  ? new URL(ogImageUrl, Astro.url.origin).href
  : undefined;

// hreflang: find translation in the other locale
const otherLocale = locale === "zh-CN" ? "en" : "zh-CN";
const allPosts = await getCollection("posts");
const currentKey = post.data.translationKey ?? post.data.slug ?? getPostSlug(post.id, post.filePath).replace(/^\//, "");
const translation = allPosts.find(p => {
  if (p.data.locale !== otherLocale) return false;
  const pKey = p.data.translationKey ?? p.data.slug ?? getPostSlug(p.id, p.filePath).replace(/^\//, "");
  return pKey === currentKey;
});
const xDefaultLocale = config.site.lang;
const defaultUrl = getRelativeLocaleUrl(xDefaultLocale, `posts/${currentKey}`);
---

<PostLayout
  title={`${title} | ${config.site.title}`}
  description={description}
  ogImage={ogImage}
  canonicalURL={canonicalURL}
  pubDatetime={pubDatetime}
  modDatetime={modDatetime}
>
  <Fragment slot="head">
    <link rel="alternate" hreflang={locale} href={new URL(getPostUrl(post.id, post.filePath, locale, post.data.slug), Astro.site).href} />
    {translation && (
      <link rel="alternate" hreflang={otherLocale} href={new URL(getPostUrl(translation.id, translation.filePath, otherLocale, translation.data.slug), Astro.site).href} />
    )}
    <link rel="alternate" hreflang="x-default" href={new URL(defaultUrl, Astro.site).href} />
  </Fragment>
  <Header />

  <div class="mx-auto max-w-[90rem] w-full px-4">
    <div class="flex justify-center gap-6 lg:gap-10">
      <!-- TOC sidebar -->
      <aside class="hidden lg:block w-52 shrink-0">
        <nav id="toc-sidebar" class="sticky top-24 max-h-[calc(100vh-8rem)] overflow-y-auto">
          <div class="text-xs font-semibold text-foreground/40 mb-3 tracking-wide uppercase">目录</div>
          <div id="toc-list"></div>
        </nav>
      </aside>

      <main
        id="main-content"
        class:list={["min-w-0 w-full max-w-3xl pb-4", { "mt-8": !config.features.showBackButton }]}
        data-pagefind-body
      >
        <BackButton />

        <h1
          style={{ viewTransitionName: toTransitionName(title) }}
          class="text-accent inline-block text-2xl font-bold sm:text-3xl"
        >
          {title}
        </h1>

        <div class="my-2 flex items-center gap-2">
          <Datetime {pubDatetime} {modDatetime} {timezone} size="lg" />
          <span
            aria-hidden="true"
            class:list={[
              "text-muted-foreground max-sm:hidden",
              { hidden: !config.features.editPost?.enabled || hideEditPost },
            ]}
          >
            |
          </span>
          <EditPost {hideEditPost} {post} class="max-sm:hidden" />
        </div>

        <article
          id="article"
          class:list={[
            "mt-8 w-full",
            "app-prose max-w-app",
            "prose-pre:bg-(--shiki-light-bg) dark:prose-pre:bg-(--shiki-dark-bg)",
          ]}
        >
          <Content />
        </article>

        <hr class="my-8 border-dashed" />

        <EditPost class="sm:hidden" {hideEditPost} {post} />

        <BackToTopButton />

        <ul class="mt-4 mb-8 flex flex-wrap gap-4 sm:my-8">
          {tags.map((tag: string) => <Tag tag={slugifyStr(tag)} tagName={tag} size="sm" />)}
        </ul>

        <ShareLinks />

        <hr class="my-8 border-dashed" />

        <AdjacentPostNav {prevPost} {nextPost} />
      </main>
    </div>
  </div>
  <Footer />
</PostLayout>

<script is:inline data-astro-rerun>
  function createProgressBar() {
    const progressContainer = document.createElement("div");
    progressContainer.className =
      "progress-container fixed top-0 z-10 h-1 w-full bg-background";

    const progressBar = document.createElement("div");
    progressBar.className = "progress-bar h-1 w-0 bg-accent";
    progressBar.id = "myBar";

    progressContainer.appendChild(progressBar);
    document.body.appendChild(progressContainer);
  }
  createProgressBar();

  function updateScrollProgress() {
    document.addEventListener("scroll", () => {
      const winScroll =
        document.body.scrollTop || document.documentElement.scrollTop;
      const height =
        document.documentElement.scrollHeight -
        document.documentElement.clientHeight;
      const scrolled = (winScroll / height) * 100;
      if (document) {
        const myBar = document.getElementById("myBar");
        if (myBar) {
          myBar.style.width = scrolled + "%";
        }
      }
    });
  }
  updateScrollProgress();

  function addHeadingLinks() {
    const headings = Array.from(
      document.querySelectorAll("h2, h3, h4, h5, h6")
    );
    for (const heading of headings) {
      heading.classList.add("group");
      const link = document.createElement("a");
      link.className =
        "heading-link ms-2 no-underline opacity-75 md:opacity-0 md:group-hover:opacity-100 md:focus:opacity-100";
      link.href = "#" + heading.id;

      const span = document.createElement("span");
      span.ariaHidden = "true";
      span.innerText = "#";
      link.appendChild(span);
      heading.appendChild(link);
    }
  }
  addHeadingLinks();

  function buildTOC() {
    const tocList = document.getElementById("toc-list");
    if (!tocList) return;

    const headings = document.querySelectorAll("#article h2, #article h3");
    if (headings.length === 0) {
      const sidebar = document.getElementById("toc-sidebar");
      if (sidebar) sidebar.style.display = "none";
      return;
    }

    const els = [...headings];
    const linkMap = new Map();

    els.forEach((h) => {
      const a = document.createElement("a");
      a.href = "#" + h.id;
      a.className =
        "block py-1 text-foreground/60 hover:text-accent transition-colors text-sm truncate border-l-2 border-transparent";
      if (h.tagName === "H3") a.classList.add("pl-4", "text-xs");
      a.textContent = h.textContent?.replace(/#$/, "").trim();
      tocList.appendChild(a);
      linkMap.set(h.id, a);
    });

    function updateActive() {
      let activeId = els[0]?.id ?? null;
      for (const h of els) {
        if (h.getBoundingClientRect().top < 120) activeId = h.id;
      }
      linkMap.forEach((a, id) => {
        const isActive = id === activeId;
        a.classList.toggle("text-accent", isActive);
        a.classList.toggle("border-accent", isActive);
        a.classList.toggle("font-medium", isActive);
        if (!isActive) {
          a.classList.remove("text-accent", "border-accent", "font-medium");
        }
      });
    }

    // Use IntersectionObserver to trigger updates efficiently
    const observer = new IntersectionObserver(
      () => updateActive(),
      { threshold: [0, 0.25, 0.5, 0.75, 1] }
    );
    els.forEach((h) => observer.observe(h));

    // Also update on scroll for smooth tracking
    window.addEventListener("scroll", updateActive, { passive: true });
  }
  buildTOC();

  function attachCopyButtons() {
    const copyButtonLabel = "Copy";
    const codeBlocks = Array.from(document.querySelectorAll("pre"));

    for (const codeBlock of codeBlocks) {
      const wrapper = document.createElement("div");
      wrapper.style.position = "relative";

      const computedStyle = getComputedStyle(codeBlock);
      const hasFileNameOffset =
        computedStyle.getPropertyValue("--file-name-offset").trim() !== "";

      const topClass = hasFileNameOffset
        ? "top-(--file-name-offset)"
        : "-top-3";

      const copyButton = document.createElement("button");
      copyButton.className = `copy-code absolute end-3 ${topClass} rounded bg-muted border border-muted px-2 py-1 text-xs leading-4 text-foreground font-medium`;
      copyButton.innerHTML = copyButtonLabel;
      codeBlock.setAttribute("tabindex", "0");
      codeBlock.appendChild(copyButton);

      codeBlock?.parentNode?.insertBefore(wrapper, codeBlock);
      wrapper.appendChild(codeBlock);

      copyButton.addEventListener("click", async () => {
        await copyCode(codeBlock, copyButton);
      });
    }

    async function copyCode(block, button) {
      const code = block.querySelector("code");
      const text = code?.innerText;

      await navigator.clipboard.writeText(text ?? "");

      button.innerText = "Copied";

      setTimeout(() => {
        button.innerText = copyButtonLabel;
      }, 700);
    }
  }
  attachCopyButtons();

  document.addEventListener("astro:after-swap", () =>
    window.scrollTo({ left: 0, top: 0, behavior: "instant" })
  );
</script>
